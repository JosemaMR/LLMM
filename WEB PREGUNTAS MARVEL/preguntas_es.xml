<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE test [

<!ELEMENT test (question+)>
<!ELEMENT question (wording,image,choices)>
<!ELEMENT wording (#PCDATA)>
<!ELEMENT image (#PCDATA)>
